# Copy to `.env` or export in your shell. Never commit real tokens.

# --- Transport ---
# stdio (default): local Cursor / Claude spawning the binary
# http: Streamable HTTP for remote clients (TLS terminates at reverse proxy)
MCP_TRANSPORT=http

# --- HTTP ---
HOST=0.0.0.0
PORT=8787
HEALTH_PATH=/health
# MCP paths (defaults in code): POST /mcp (streamable), GET /sse + POST /messages (legacy SSE)

# Public hostname(s) for Host header validation (comma-separated). Required when binding 0.0.0.0.
# Example: mcp.example.com,localhost
MCP_ALLOWED_HOSTS=

# --- Auth ---
# When set, POST /mcp requires Authorization: Bearer <token>
MCP_AUTH_TOKEN=

# --- Skills ---
# Directory tree rooted here; each skill is a folder containing SKILL.md
SKILLS_ROOT=./skills

# --- MCP metadata ---
MCP_SERVER_NAME=skills-mcp-server
MCP_SERVER_VERSION=1.0.0
