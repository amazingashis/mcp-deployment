# Copy to `.env` or export in your shell. Never commit real tokens.

# --- Transport ---
# stdio (default): local Cursor / Claude spawning the binary
# http: Streamable HTTP for remote clients (TLS terminates at reverse proxy)
MCP_TRANSPORT=http

# --- HTTP ---
HOST=0.0.0.0
PORT=8787
HEALTH_PATH=/health
# MCP paths (defaults in code): POST /mcp (streamable), GET /sse + POST /messages (legacy SSE)

# Public hostname(s) for Host header validation (comma-separated). Required when binding 0.0.0.0.
# Example: mcp.example.com,localhost
MCP_ALLOWED_HOSTS=

# --- Auth ---
# When set, POST /mcp requires Authorization: Bearer <token>
MCP_AUTH_TOKEN=

# --- Skills ---
# Directory tree rooted here; each skill is a folder containing SKILL.md
SKILLS_ROOT=./skills

# --- MCP metadata ---
MCP_SERVER_NAME=skills-mcp-server
MCP_SERVER_VERSION=1.0.0

# --- Usage audit (optional NDJSON append; no PHI in logs — review before enabling in regulated environments) ---
# Enable explicitly, or omit MCP_USAGE_TRACKING and set MCP_USAGE_LOG to a file path instead.
MCP_USAGE_TRACKING=false
# Relative paths resolve from cwd; parent dirs are created automatically.
MCP_USAGE_LOG=reports/skills-mcp-usage.ndjson
# Stable salt so authCredentialHash survives process restarts (required for comparable “user keys” across deploys).
# MCP_USAGE_HASH_SALT=
# Comma-separated request header names recorded as salted hashes only (e.g. project id injected by proxy).
# MCP_USAGE_EXTRA_HEADERS=x-project-id,x-workspace-hash

# --- Usage web dashboard (HTTP transport only; same URL as MCP on Render/Railway/Fly/etc.) ---
# On PaaS, point MCP_USAGE_LOG at a writable path, e.g. /tmp/skills-mcp-usage.ndjson
# MCP_USAGE_TRACKING=true
# MCP_USAGE_LOG=/tmp/skills-mcp-usage.ndjson
# MCP_USAGE_WEB=true
# MCP_USAGE_WEB_PATH=/usage
# MCP_USAGE_WEB_USER=cursor
# MCP_USAGE_WEB_PASSWORD=cursor
# MCP_USAGE_HASH_SALT=set-a-long-random-secret-in-hosted-secrets-ui
