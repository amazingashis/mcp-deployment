{
  "name": "skills-mcp-server",
  "version": "1.0.0",
  "description": "Client-agnostic MCP server exposing SKILL.md packs as resources, tools, and prompts (stdio + Streamable HTTP).",
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "skills-mcp-server": "./dist/main.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:http": "cross-env MCP_TRANSPORT=http node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "dev:http": "cross-env MCP_TRANSPORT=http tsx watch src/main.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "skills",
    "cursor",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist",
    "skills",
    "README.md",
    "HOSTING_AND_CURSOR.md",
    "DEPLOYMENT.md",
    "env.example",
    "Dockerfile"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
